YUMMYDOORS_APP_NAME=YummyDoors API
YUMMYDOORS_APP_ENV=production
YUMMYDOORS_DEBUG=false
YUMMYDOORS_DB_ECHO=false
YUMMYDOORS_API_V1_PREFIX=/api/v1

YUMMYDOORS_POSTGRES_HOST=postgres
YUMMYDOORS_POSTGRES_PORT=5432
YUMMYDOORS_POSTGRES_DB=yummydoors
YUMMYDOORS_POSTGRES_USER=postgres
YUMMYDOORS_POSTGRES_PASSWORD=change-this-password
YUMMYDOORS_DATABASE_URL=postgresql+asyncpg://postgres:change-this-password@postgres:5432/yummydoors

# Optional direct connection to Yummy POS database if the VPS can reach it.
YUMMYDOORS_POS_DATABASE_URL=

YUMMYDOORS_JWT_SECRET_KEY=change-this-to-a-long-random-secret
YUMMYDOORS_JWT_ALGORITHM=HS256
YUMMYDOORS_ACCESS_TOKEN_EXPIRE_MINUTES=30
YUMMYDOORS_REFRESH_TOKEN_EXPIRE_MINUTES=10080
YUMMYDOORS_RESET_CODE_EXPIRE_MINUTES=10
YUMMYDOORS_DEBUG_EXPOSE_RESET_CODE=false

YUMMYDOORS_CORS_ORIGINS=https://doors.example.com,https://www.doors.example.com

YUMMYDOORS_SMTP_HOST=smtp.gmail.com
YUMMYDOORS_SMTP_PORT=587
YUMMYDOORS_SMTP_USERNAME=
YUMMYDOORS_SMTP_PASSWORD=
YUMMYDOORS_SMTP_FROM_EMAIL=
YUMMYDOORS_SMTP_USE_TLS=true
YUMMYDOORS_SMTP_USE_SSL=false

YUMMYDOORS_GOOGLE_CLIENT_ID=

YUMMYDOORS_APP_PORT=8010
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
RUN_MIGRATIONS=1

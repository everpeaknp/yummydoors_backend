YUMMYDOORS_APP_NAME=YummyDoors API
YUMMYDOORS_APP_ENV=development
YUMMYDOORS_DEBUG=true
YUMMYDOORS_DB_ECHO=false
YUMMYDOORS_API_V1_PREFIX=/api/v1
YUMMYDOORS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/yummydoors
YUMMYDOORS_POS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/yummy_local
YUMMYDOORS_JWT_SECRET_KEY=change-this-secret-key-to-a-long-random-value
YUMMYDOORS_JWT_ALGORITHM=HS256
YUMMYDOORS_ACCESS_TOKEN_EXPIRE_MINUTES=30
YUMMYDOORS_REFRESH_TOKEN_EXPIRE_MINUTES=10080
YUMMYDOORS_RESET_CODE_EXPIRE_MINUTES=10
YUMMYDOORS_DEBUG_EXPOSE_RESET_CODE=true
YUMMYDOORS_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
YUMMYDOORS_SMTP_HOST=
YUMMYDOORS_SMTP_PORT=587
YUMMYDOORS_SMTP_USERNAME=
YUMMYDOORS_SMTP_PASSWORD=
YUMMYDOORS_SMTP_FROM_EMAIL=
YUMMYDOORS_SMTP_USE_TLS=true
YUMMYDOORS_SMTP_USE_SSL=false
YUMMYDOORS_GOOGLE_CLIENT_ID=
YUMMYDOORS_POSTGRES_HOST=localhost
YUMMYDOORS_POSTGRES_PORT=5434
YUMMYDOORS_POSTGRES_DB=yummydoors
YUMMYDOORS_POSTGRES_USER=postgres
YUMMYDOORS_POSTGRES_PASSWORD=postgres
